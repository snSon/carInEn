rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /raw_telematics_logs/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    match /telematics_logs/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    match /user_preferences/{uid} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == uid || request.auth.token.role == "admin");
    }

  }
}
